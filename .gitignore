# =============================================================
#  DentaFlow Monorepo — .gitignore
# =============================================================

# ── Dependencies ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ── Build Outputs ─────────────────────────────────────────────
.next/
out/
dist/
build/
.turbo/

# ── Environment / Secrets ──────────────────────────────────────
# NEVER commit real secrets
.env
.env.local
.env.*.local
.env.production
.env.production.local
# DO commit examples:
# .env.example  ← intentionally tracked
# .env.local.example  ← intentionally tracked

# ── Prisma Generated ──────────────────────────────────────────
# Schema is committed; generated client is not
backend/node_modules/
# migrations are committed (source of truth)

# ── Logs ──────────────────────────────────────────────────────
*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
/tmp/

# ── Testing / Coverage ────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── OS Junk ───────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.claude/

# ── Docker ────────────────────────────────────────────────────
# docker-compose.yml IS committed (it's config)
# Data volumes are not
postgres_data/
redis_data/
n8n_data/

# ── Misc binaries / temp files ────────────────────────────────
cloudflared.exe
*.exe
*.pem
*.key
*.cert
test.claude
untitled-*
/tmp

# ── Uploads (placeholder dirs are committed, not contents) ────
dashboard/uploads/*
!dashboard/uploads/.gitkeep
backend/uploads/*
!backend/uploads/.gitkeep

# ── Vercel ────────────────────────────────────────────────────
.vercel

# ── n8n local data ────────────────────────────────────────────
# Exported workflow JSONs in /workflows ARE committed
.n8n/
n8n_data/
