# =============================================================
#  DentaFlow Backend — Environment Variables
#  Copy this file:  cp .env.example .env
#  Then fill in real values before starting the server.
# =============================================================

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development            # development | production

# Allowed CORS origin (your dashboard URL)
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL via Prisma) ─────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/dental_saas?schema=public"

# ── Authentication (JWT) ──────────────────────────────────────
# MUST be at least 32 random characters in production
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=24h

# ── Evolution API (WhatsApp) ──────────────────────────────────
# Your Evolution API server URL (self-hosted or cloud)
EVOLUTION_API_BASE_URL=http://your-evolution-server:8080
# Global API key from Evolution API settings
EVOLUTION_API_KEY=your_evolution_api_key_here
# Default WhatsApp instance name (must match Evolution API instance)
DEFAULT_WA_INSTANCE=your-instance-name

# ── n8n Automation Integration ────────────────────────────────
# Full webhook URL that receives WhatsApp events
# e.g. https://your-n8n.example.com/webhook/clinic-whatsapp
N8N_MASTER_ROUTER_URL=https://your-n8n-instance/webhook/clinic-whatsapp

# Shared secret protecting /internal/n8n/* routes
# Must match X-N8N-Secret header in n8n HTTP Request nodes
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
N8N_INTERNAL_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET

# ── Public Tunnel URL (n8n callback to this backend) ─────────
# n8n (remote) calls back to this backend via a public URL.
# Options: Cloudflare Tunnel (prod), ngrok/serveo (dev)
# Example: https://dentaflow.yourdomain.com
BACKEND_PUBLIC_URL=https://your-public-backend-url
